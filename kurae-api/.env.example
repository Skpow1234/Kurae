# Server
PORT=8080
ENV=development
# Production: set to your deployed web origin(s), comma-separated (must not be localhost-only).
CORS_ORIGINS=http://localhost:3000

# Database — host tools (make migrate-up, make seed) use localhost.
# Docker Compose overrides these for api/worker containers (host: postgres, redis).
DATABASE_URL=postgres://kurae:kurae@localhost:5432/kurae?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (use a random 32+ char secret in production)
JWT_SECRET=change-me-in-production

# Payments — required for Block A Stripe E2E and production.
# Development: sk_test_... from https://dashboard.stripe.com/test/apikeys
# Production: sk_live_... only (test keys are rejected when ENV=production)
# Webhook secret: stripe listen --forward-to http://localhost:8080/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public API base URL for payment provider webhooks (defaults to http://localhost:PORT)
API_PUBLIC_URL=http://localhost:8080

# LATAM payment providers (optional — route by drop currency)
# COP: Wompi → PayU → Mercado Pago; BRL/MXN/ARS/CLP/PEN/UYU: Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
PAYU_API_LOGIN=
PAYU_API_KEY=
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=

# Email (worker uses Resend or Postmark when configured; otherwise logs)
EMAIL_FROM=orders@kurae.dev
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# S3 product images
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
