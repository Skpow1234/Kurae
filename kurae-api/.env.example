# Server
PORT=8080
ENV=development
CORS_ORIGINS=http://localhost:3000

# Database — host tools (make migrate-up, make seed) use localhost.
# Docker Compose overrides these for api/worker containers (host: postgres, redis).
DATABASE_URL=postgres://kurae:kurae@localhost:5432/kurae?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (use a random 32+ char secret in production)
JWT_SECRET=change-me-in-production

# Payments — required for Block A Stripe E2E and production.
# Get test keys from https://dashboard.stripe.com/test/apikeys
# Webhook secret: stripe listen --forward-to http://localhost:8080/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (worker uses Resend or Postmark when configured; otherwise logs)
EMAIL_FROM=orders@kurae.dev
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# S3 product images
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
