# Server
PORT=8080
ENV=development
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://kurae:kurae@localhost:5432/kurae?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (use a random 32+ char secret in production)
JWT_SECRET=change-me-in-production

# Payments — leave empty in local dev to use noop provider (pi_dev_* intents, no webhooks)
# Required when ENV=production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (worker uses Resend or Postmark when configured; otherwise logs)
EMAIL_FROM=orders@kurae.dev
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# S3 product images
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
