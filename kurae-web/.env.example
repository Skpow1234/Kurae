# Required — kurae-api base URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# Required for checkout — Stripe publishable key (test: pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional — S3 image hostname for Next.js Image (e.g. my-bucket.s3.us-east-1.amazonaws.com)
# Set when kurae-api S3_BUCKET + AWS credentials are configured.
NEXT_PUBLIC_S3_IMAGE_HOSTNAME=

# Optional — PostHog product analytics (runs alongside first-party seller analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
